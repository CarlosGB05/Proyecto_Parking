<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Proyecto_Parking.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:DataType="viewModels:MainWindowViewModel"
             x:Class="InformeEventos.Views.CircularView.InformeLineas2View">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    <Grid ColumnDefinitions="*,*"
          Margin="20">

        <!-- ===================== -->
        <!-- COLUMNA IZQUIERDA -->
        <!-- ENUNCIADO -->
        <!-- ===================== -->
        <Border Grid.Column="0"
                Padding="20"
                CornerRadius="8"
                Background="WhiteSmoke">

            <StackPanel Spacing="12">

                <TextBlock Text="Informe gráfico · Distribución de asistentes por género"
                           FontSize="18"
                           FontWeight="Bold" />

                <TextBlock TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="DimGray"
                           Text="Este informe muestra un gráfico circular que representa la distribución de los asistentes registrados en el sistema según su género." />

                <TextBlock TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="DimGray"
                           Text="Cada sector del gráfico corresponde a un género distinto, permitiendo analizar visualmente el peso relativo de cada grupo." />

                <TextBlock TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="DimGray"
                           Text="No se aplican filtros en este informe, ofreciendo una visión global de los asistentes." />

            </StackPanel>
        </Border>

        <!-- ===================== -->
        <!-- COLUMNA DERECHA -->
        <!-- ACCIONES -->
        <!-- ===================== -->
        <Border Grid.Column="1"
                Padding="20"
                CornerRadius="8"
                Background="WhiteSmoke"
                BorderBrush="LightGray"
                BorderThickness="1">

            <StackPanel Spacing="16">

                <TextBlock Text="Opciones del informe"
                           FontSize="16"
                           FontWeight="Bold" />

                <TextBlock Text="Este informe no requiere filtros."
                           FontSize="13"
                           Foreground="DimGray" />

                <Separator />

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Generar gráfico"
                            Width="150"
                            Height="36"
                             />
                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>

</UserControl>