<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Proyecto_Parking.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1750" d:DesignHeight="930"
             Height="930" Width="1750"
             x:DataType="viewModels:MainWindowViewModel"
             x:Class="InformeEventos.Views.CircularView.InformeCircular3View">
    
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    
    <UserControl.Background>
        <ImageBrush Source="avares://Proyecto_Parking/Assets/fondo.png"
                    Stretch="UniformToFill"/>
    </UserControl.Background>
    
    <Grid ShowGridLines="False" Width="800"
          Margin="20" HorizontalAlignment="Center">

    <!-- ===================== -->
    <!-- COLUMNA IZQUIERDA -->
    <!-- ENUNCIADO -->
    <!-- ===================== -->
    <Border Grid.Column="0"
            Padding="20"
            Height="700"
            CornerRadius="8"
            Background="WhiteSmoke">

        <StackPanel Spacing="12">

            <TextBlock Text="Informe Circular 3 · Cantidad Ingresos por Localidad"
                       FontSize="23"
                       FontWeight="Bold"
                       Foreground="Black"
                       HorizontalAlignment="Center"/>

            <TextBlock TextWrapping="Wrap"
                       FontSize="16"
                       Foreground="DimGray"
                       HorizontalAlignment="Center"
                       Text="Este informe presenta un gráfico circular que muestra la distribución proporcional de los ingresos generados según su localidad de origen." />

            <TextBlock TextWrapping="Wrap"
                       FontSize="16"
                       Foreground="DimGray"
                       HorizontalAlignment="Center"
                       Text="Cada sector del gráfico representa una ubicación geográfica diferente, permitiendo visualizar rápidamente qué localidades tienen el mayor impacto en la recaudación total." />

            <TextBlock TextWrapping="Wrap"
                       FontSize="16"
                       Foreground="DimGray"
                       HorizontalAlignment="Center"
                       Text="Este informe ofrece una visión global consolidada, por lo que se genera directamente con todos los datos disponibles en el sistema." />

            <TextBlock Text="Filtros del informe"
                       FontSize="20"
                       FontWeight="Bold" 
                       Foreground="Black"
                       Margin="0,30,0,0"/>

            <TextBlock Text="Este informe no requiere filtros."
                       FontSize="16"
                       Foreground="DimGray" />
            
            <Separator />
                
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Content="Generar informe" FontSize="18"
                        Width="170" Height="40" Margin="0,0,10,0"
                        Command="{Binding InformeCircular3Command}" />
            </StackPanel>
            
        </StackPanel>
    </Border>

</Grid>

</UserControl>
