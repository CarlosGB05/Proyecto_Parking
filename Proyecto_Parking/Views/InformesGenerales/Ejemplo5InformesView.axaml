<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Proyecto_Parking.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             x:DataType="viewModels:MainWindowViewModel"
             x:Class="InformeEventos.Views.InformesViews.Ejemplo5InformesView">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    <Grid ColumnDefinitions="*,*"
          ShowGridLines="False"
          Margin="20">

        <!-- ===================== -->
        <!-- COLUMNA IZQUIERDA -->
        <!-- ENUNCIADO -->
        <!-- ===================== -->
        <Border Grid.Column="0"
                Padding="20"
                CornerRadius="8"
                Background="WhiteSmoke">

            <StackPanel Spacing="12">

                <TextBlock Text="Informe 5 · Entradas y asistencia por festival"
                           FontSize="18"
                           FontWeight="Bold" />

                <TextBlock TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="DimGray"
                           Text="Este informe presenta un resumen de las entradas vendidas para un festival concreto, agrupadas por tipo de entrada." />

                <TextBlock TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="DimGray"
                           Text="Se muestra el número de entradas vendidas y los ingresos generados por cada tipo, así como el total global del festival." />

                <TextBlock TextWrapping="Wrap"
                           FontSize="14"
                           Foreground="DimGray"
                           Text="Este informe resulta útil para el análisis económico y el control de la asistencia." />

            </StackPanel>
        </Border>

        <!-- ===================== -->
        <!-- COLUMNA DERECHA -->
        <!-- FILTROS Y ACCIONES -->
        <!-- ===================== -->
        <Border Grid.Column="1"
                Padding="20"
                CornerRadius="8"
                Background="WhiteSmoke"
                BorderBrush="LightGray"
                BorderThickness="1">

            <StackPanel Spacing="16">

                <TextBlock Text="Opciones del informe"
                           FontSize="16"
                           FontWeight="Bold" />

                <!-- Festival -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Festival"
                               FontSize="13"
                               Foreground="DimGray" />
                    <ComboBox PlaceholderText="Seleccionar festival"
                              ItemsSource="{Binding }"
                              SelectedItem="{Binding }" />
                </StackPanel>

                <Separator />

                <!-- Botón -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Generar informe"
                            Width="150"
                            Height="36"
                            Command="{Binding EntradasPorFestivalCommand}" />
                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>

</UserControl>