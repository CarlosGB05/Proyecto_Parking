<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Proyecto_Parking.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1750" d:DesignHeight="830"
             Height="830" Width="1750"
             x:DataType="viewModels:MainWindowViewModel"
             x:Class="InformeEventos.Views.InformesViews.InformeGeneral4View"
             Background="BlueViolet">
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    
    <Grid ShowGridLines="False" Width="800"
          Margin="20" HorizontalAlignment="Center">

        <!-- ===================== -->
        <!-- COLUMNA IZQUIERDA -->
        <!-- ENUNCIADO -->
        <!-- ===================== -->
        <Border Grid.Column="0"
                Padding="20"
                CornerRadius="8"
                Height="700"
                Background="WhiteSmoke">

            <StackPanel Spacing="12">

                <TextBlock Text="Informe 4 · Listado de Estacionados por Fechas"
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="Black"
                           HorizontalAlignment="Center"/>

                <TextBlock TextWrapping="Wrap"
                           FontSize="16"
                           Foreground="DimGray"
                           Text="Este informe permite consultar el listado de festivales aplicando distintos filtros para acotar la información mostrada." />

                <TextBlock TextWrapping="Wrap"
                           FontSize="16"
                           Foreground="DimGray"
                           Text="El usuario puede filtrar los festivales por ubicación, rango de fechas y estado, obteniendo así un informe adaptado a sus necesidades de análisis." />

                <TextBlock TextWrapping="Wrap"
                           FontSize="16"
                           Foreground="DimGray"
                           Text="Los resultados se muestran en formato tabla, incluyendo aforo, entradas vendidas e ingresos generados por cada festival que cumpla los criterios seleccionados."/>
                
                <TextBlock Text="Filtros del informe"
                           FontSize="20"
                           FontWeight="Bold" 
                           Foreground="Black"
                           Margin="0,30,0,0"/>

                
                <!-- Ubicación -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Ubicación del Parking"
                               FontSize="16"
                               Foreground="DimGray"
                               Margin="0,5,0,15"
                               HorizontalAlignment="Center"/>
                    <ComboBox PlaceholderText="    Seleccionar ubicación"
                              Background="Black" CornerRadius="20"
                              Width="450" Height="45" FontSize="18"
                              Margin="0,0,0,30"
                              Name="ComboParking"
                              ItemsSource="{Binding ListaParking}" />
                </StackPanel>

                <TextBlock Text="Fechas del Estacionamiento"
                           FontSize="16"
                           Foreground="DimGray"
                           Margin="0,5,0,0"
                           HorizontalAlignment="Center"/>
                <!-- Rango de fechas -->
                <Border Background="Black" CornerRadius="20" 
                        Width="450" Height="120">
                    <StackPanel Orientation="Horizontal" Spacing="20"
                                HorizontalAlignment="Center">
                        <StackPanel Spacing="4"
                                    Width="150">
                            <TextBlock Text="Fecha inicio"
                                       FontSize="16"
                                       Foreground="DimGray"
                                       Margin="0,10,0,5"/>
                            <DatePicker SelectedDate="{Binding FechaInicio}" />
                        </StackPanel>

                        <StackPanel Spacing="4"
                                    Width="150">
                            <TextBlock Text="Fecha fin"
                                       FontSize="13"
                                       Foreground="DimGray"
                                       Margin="0,10,0,5"/>
                            <DatePicker SelectedDate="{Binding FechaFin}" />
                        </StackPanel>

                    </StackPanel>
                </Border>
                

                <Separator />

                <!-- Botones -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Spacing="10">

                    <Button Content="Generar Informe" FontSize="18"
                            Width="170" Height="40"
                            Command="{Binding InformesGenerales4Command }"
                            CommandParameter="{Binding ElementName=ComboParking, Path=SelectedItem}"/>
                    <Button Content="Limpiar" FontSize="18"
                            Width="170" Height="40" />
                </StackPanel>

            </StackPanel>
        </Border>

    </Grid>
</UserControl>