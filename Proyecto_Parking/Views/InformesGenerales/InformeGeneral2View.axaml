<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:Proyecto_Parking.ViewModels"
             mc:Ignorable="d" d:DesignWidth="1750" d:DesignHeight="930"
             Height="930" Width="1750"
             x:DataType="viewModels:MainWindowViewModel"
             x:Class="InformeEventos.Views.InformesViews.InformeGeneral2View">
    
    <Design.DataContext>
        <viewModels:MainWindowViewModel />
    </Design.DataContext>
    
    <UserControl.Background>
        <ImageBrush Source="avares://Proyecto_Parking/Assets/fondo.png"
                    Stretch="UniformToFill"/>
    </UserControl.Background>
    
    <Grid ShowGridLines="False" Width="800"
          Margin="20" HorizontalAlignment="Center">

        <!-- ===================== -->
        <!-- COLUMNA IZQUIERDA -->
        <!-- ENUNCIADO -->
        <!-- ===================== -->
        <Border Grid.Column="0"
                Padding="20"
                CornerRadius="8"
                Height="700"
                Background="WhiteSmoke">

            <StackPanel Spacing="12">

                <TextBlock Text="Informe 2 · Vehiculos segun su Marca"
                           FontSize="23"
                           FontWeight="Bold"
                           Foreground="Black"
                           HorizontalAlignment="Center"/>

                <TextBlock TextWrapping="Wrap"
                           FontSize="16"
                           Foreground="DimGray"
                           HorizontalAlignment="Center"
                           Text="Este informe muestra un listado de todos los vehiculos registrados a partir de la Marca del vehiculo." />

                <TextBlock TextWrapping="Wrap"
                           FontSize="16"
                           Foreground="DimGray"
                           HorizontalAlignment="Center"
                           Text="Se incluyen datos como el Id del registro, la marca, la matricula, el nombre del Cliente y el DNI del cliente." />

                <TextBlock TextWrapping="Wrap"
                           FontSize="16"
                           Foreground="DimGray"
                           HorizontalAlignment="Center"
                           Text="El objetivo es ofrecer una visión clara de la cantidad de marcas que se utilizan a diario." />

                <TextBlock Text="Filtros del informe"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="Black"
                           Margin="0,30,0,0"/>

                <!-- Festival -->
                <StackPanel Spacing="4">
                    <TextBlock Text="Marca del Vehiculo"
                               FontSize="16" Foreground="Black" 
                               Margin="0,5,0,15"
                               HorizontalAlignment="Center"/>
                    <ComboBox PlaceholderText="     Selecciona Marca del Vehiculo"
                              Background="Black" Width="450" Height="45"
                              Name="ComboMarcas" CornerRadius="20" FontSize="18"
                              ItemsSource="{Binding MarcaVehiculos}"/>
                </StackPanel>

                <Separator />

                <!-- Botón -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">

                    <Button Content="Generar informe" FontSize="18"
                            Width="170" Height="40" Margin="0,0,10,0"
                            Command="{Binding InformesGenerales2Command}" 
                            CommandParameter="{Binding ElementName=ComboMarcas, Path=SelectedItem}"/>
                </StackPanel>
                
            </StackPanel>
        </Border>
    </Grid>

</UserControl>